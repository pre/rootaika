#!/usr/bin/env bash
# One-command release entry point: drafts the GitHub release (generated notes,
# pinned to HEAD) and dispatches the build workflow, which attaches the assets
# to the draft. Review in the browser once the assets appear, then publish;
# publishing creates the tag and locks the release (immutable releases).
# See README.md "Publishing a release".
#
# Usage: bin/release-github v1.2.3
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "usage: $0 <version-tag>   e.g. $0 v1.2.3" >&2
  exit 2
fi

exec make -C "$(dirname "$0")/../client-windows" github-release VERSION="$1"
